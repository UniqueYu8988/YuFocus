{
  "name": "shijie-focus-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "视界专注 v0.1 桌面客户端",
  "author": "Yu",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "prepare:release": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-release.ps1",
    "package:share": "powershell -ExecutionPolicy Bypass -File ./scripts/package-share.ps1",
    "build:web": "powershell -ExecutionPolicy Bypass -File ./scripts/clean-build-output.ps1 && tsc && vite build",
    "build": "npm run prepare:release && npm run build:web && electron-builder && npm run package:share",
    "build:portable": "npm run prepare:release && npm run build:web && electron-builder --win portable --publish never && npm run package:share",
    "build:mirror": "npm run prepare:release && npm run build:web && set \"ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/\" && set \"ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/\" && electron-builder && npm run package:share",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^10.1.0",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "overrides": {
    "cacache": {
      "glob": "^10.5.0"
    },
    "lodash": "^4.18.0",
    "@xmldom/xmldom": "^0.9.9"
  },
  "build": {
    "appId": "com.yu.shijiezhuanzhu",
    "productName": "视界专注",
    "directories": {
      "output": "release"
    },
    "artifactName": "视界专注_v${version}_${arch}.${ext}",
    "extraResources": [
      {
        "from": "../src",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../assets/app_icon.ico",
        "to": "assets/app_icon.ico"
      }
    ],
    "files": [
      "dist",
      "dist-electron",
      "!node_modules/.cache"
    ],
    "win": {
      "icon": "../assets/app_icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "asar": true,
    "compression": "maximum"
  }
}
