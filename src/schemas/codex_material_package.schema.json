{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shijie-focus.local/schemas/codex_material_package.schema.json",
  "title": "Shijie Focus Codex Material Package",
  "description": "Codex-friendly source material package generated from subtitles or local transcripts for knowledge synthesis.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "material_id",
    "source",
    "acquisition",
    "files",
    "block_count",
    "text_length",
    "processing_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "onboard.codex-materials.v0.1"
    },
    "material_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,96}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_id", "title", "language", "ingested_at"],
      "properties": {
        "source_type": { "type": "string" },
        "source_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "creator": { "type": "string" },
        "url": { "type": "string" },
        "language": { "type": "string", "minLength": 2 },
        "ingested_at": { "type": "string" }
      }
    },
    "acquisition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subtitle_priority", "text_source_type", "transcription_provider", "notes"],
      "properties": {
        "subtitle_priority": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text_source_type": { "type": "string" },
        "transcription_provider": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "raw_transcript",
        "raw_tracks",
        "blocks_dir",
        "indexes_dir",
        "authoring_dir",
        "content_draft_dir",
        "codex_synthesis_prompt",
        "block_schema"
      ],
      "properties": {
        "raw_transcript": { "type": "string" },
        "raw_tracks": { "type": "string" },
        "handoff": { "type": "string" },
        "run_state": { "type": "string" },
        "handoff_status": { "type": "string" },
        "blocks_dir": { "type": "string" },
        "indexes_dir": { "type": "string" },
        "part_index": { "type": "string" },
        "teaching_map": { "type": "string" },
        "term_normalization": { "type": "string" },
        "noise_segments": { "type": "string" },
        "authoring_dir": { "type": "string" },
        "codex_synthesis_prompt": { "type": "string" },
        "codex_readonly_audit_prompt": { "type": "string" },
        "synthesis_plan": { "type": "string" },
        "synthesis_plan_schema": { "type": "string" },
        "content_draft_dir": { "type": "string" },
        "codex_goal_v8_prompt": { "type": "string" },
        "knowledge_tree": { "type": "string" },
        "tree_outline": { "type": "string" },
        "structure_review": { "type": "string" },
        "block_digest_dir": { "type": "string" },
        "topic_inventory": { "type": "string" },
        "evidence_ledger": { "type": "string" },
        "coverage_matrix": { "type": "string" },
        "block_reread_ledger": { "type": "string" },
        "section_dossiers_dir": { "type": "string" },
        "drafts_dir": { "type": "string" },
        "thinness_review": { "type": "string" },
        "learning_notes": { "type": "string" },
        "chapter_mindmap": { "type": "string" },
        "review_exports_dir": { "type": "string" },
        "block_schema": { "type": "string" }
      }
    },
    "block_count": { "type": "integer", "minimum": 0 },
    "text_length": { "type": "integer", "minimum": 0 },
    "raw_transcript_length": { "type": "integer", "minimum": 0 },
    "chunked_text_length": { "type": "integer", "minimum": 0 },
    "processing_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_block_chars", "single_pass_blocks", "coverage_strategy", "review_strategy"],
      "properties": {
        "raw_block_chars": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target", "min", "max"],
          "properties": {
            "target": { "type": "integer", "minimum": 1 },
            "min": { "type": "integer", "minimum": 1 },
            "max": { "type": "integer", "minimum": 1 }
          }
        },
        "single_pass_blocks": { "type": "string" },
        "active_workflow": { "type": "string" },
        "coverage_strategy": { "type": "string" },
        "review_strategy": { "type": "string" }
      }
    }
  },
  "$defs": {
    "materialBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "block_id",
        "order",
        "source_chunk_ids",
        "page_labels",
        "time_range",
        "estimated_tokens",
        "char_count",
        "text",
        "key_points",
        "source_excerpt",
        "codex_notes"
      ],
      "properties": {
        "schema_version": { "const": "onboard.material-block.v0.1" },
        "block_id": { "type": "string", "pattern": "^block_[0-9]{3,}$" },
        "order": { "type": "integer", "minimum": 1 },
        "source_chunk_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "page_labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "time_range": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {
            "from": { "type": ["number", "null"] },
            "to": { "type": ["number", "null"] }
          }
        },
        "estimated_tokens": { "type": "integer", "minimum": 0 },
        "char_count": { "type": "integer", "minimum": 0 },
        "text": { "type": "string" },
        "key_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_excerpt": { "type": "string" },
        "codex_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
