{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shijie-focus.local/schemas/content_synthesis_plan.schema.json",
  "title": "视界专注 Content Synthesis Plan",
  "description": "Codex 在本地维护的学习笔记工作计划。它记录视频内容边界、知识树结构、呈现建议、补全边界和写作质量契约。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "title",
    "source_boundary",
    "synthesis_goal",
    "audience",
    "sections",
    "quality_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "shijie.content-synthesis-plan.v0.1",
        "shijie.content-synthesis-plan.v0.2",
        "shijie.content-synthesis-plan.v0.3"
      ]
    },
    "plan_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_title", "content_scope", "interpretation_direction"],
      "properties": {
        "source_id": { "type": "string" },
        "source_title": { "type": "string" },
        "content_scope": { "type": "string" },
        "interpretation_direction": { "type": "string" },
        "known_limits": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        }
      }
    },
    "synthesis_goal": {
      "type": "string",
      "minLength": 10
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sectionPlan"
      }
    },
    "knowledge_tree": {
      "$ref": "#/$defs/knowledgeTree",
      "description": "v8 知识树结构锚点。v0.2 计划应填写；v0.1 计划可为空以兼容旧产物。"
    },
    "cross_links": {
      "type": "array",
      "default": [],
      "description": "跨章节、跨节点关系。用于避免 chapter_mindmap 退化为提纲。",
      "items": {
        "$ref": "#/$defs/crossLink"
      }
    },
    "presentation_policy": {
      "$ref": "#/$defs/presentationPolicy",
      "description": "学习台呈现策略。说明最终 learning_notes.md 应使用紧凑小节还是大章节+完整小节。"
    },
    "quality_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must_do", "must_not_do", "verification_notes"],
      "properties": {
        "must_do": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "must_not_do": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "verification_notes": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        }
      }
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pass_strategy": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        },
        "chunk_strategy": {
          "type": "string"
        },
        "chapter_map_format": {
          "type": "string"
        },
        "tree_first_strategy": {
          "type": "string",
          "description": "说明如何先搭知识树，再映射 topic，再深写正文。"
        },
        "review_sequence": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        }
      }
    },
  "notes": {
      "type": "array",
      "default": [],
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "shijie.content-synthesis-plan.v0.2"
          }
        }
      },
      "then": {
        "required": ["knowledge_tree"],
        "properties": {
          "execution_policy": {
            "required": ["tree_first_strategy"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "shijie.content-synthesis-plan.v0.3"
          }
        }
      },
      "then": {
        "required": ["knowledge_tree", "presentation_policy"],
        "properties": {
          "execution_policy": {
            "required": ["tree_first_strategy"]
          }
        }
      }
    }
  ],
  "$defs": {
    "presentationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "min_readable_unit", "heading_policy"],
      "properties": {
        "mode": {
          "enum": ["compact_notes", "chaptered_notes"],
          "description": "compact_notes 适合短材料或主题集中材料；chaptered_notes 适合中长材料或天然多模块材料。"
        },
        "min_readable_unit": {
          "type": "string",
          "description": "说明一个可打开学习小节应覆盖的完整阅读范围。"
        },
        "target_openable_units": {
          "type": "integer",
          "minimum": 1,
          "maximum": 40
        },
        "heading_policy": {
          "type": "string",
          "description": "说明 #、##、### 如何使用，以及哪些知识点应留在同一小节内部。"
        },
        "grouping_policy": {
          "type": "string",
          "description": "说明相邻 topic 如何合并为连续阅读小节，避免一个 topic 一页。"
        }
      }
    },
    "sectionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_id",
        "title",
        "purpose",
        "source_scope",
        "must_cover",
        "organization_hint",
        "enrichment_policy"
      ],
      "properties": {
        "section_id": {
          "type": "string",
          "pattern": "^section_[0-9]{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string"
        },
        "chapter_group": {
          "type": "string",
          "description": "该学习小节所属的 ## 章节组。"
        },
        "branch_id": {
          "type": "string",
          "description": "该小节所属知识树主分支。"
        },
        "parent_node_id": {
          "type": "string",
          "description": "该小节在知识树中的父节点。"
        },
        "child_node_ids": {
          "type": "array",
          "default": [],
          "description": "该小节覆盖的知识树子节点。子节点不必全部升级为 Markdown 可点击层级，可作为同一阅读单位内部的小标题或内容块。",
          "items": { "type": "string" }
        },
        "learning_question": {
          "type": "string",
          "description": "这一小节要帮助用户解决的核心问题。"
        },
        "readable_unit": {
          "type": "string",
          "description": "这一节作为学习台可打开内容时应覆盖的完整阅读范围。"
        },
        "internal_headings": {
          "type": "array",
          "default": [],
          "description": "建议放在同一节内部的短标题、机制卡、案例卡或边界块，不作为新的可点击层级。",
          "items": { "type": "string" }
        },
        "source_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_cover": {
          "type": "array",
          "items": { "type": "string" }
        },
        "organization_hint": {
          "enum": [
            "problem_first",
            "theme_synthesis",
            "workflow",
            "case_grouping",
            "argument_map",
            "timeline",
            "concept_map",
            "mixed"
          ]
        },
        "enrichment_policy": {
          "enum": [
            "none",
            "light_background",
            "step_completion",
            "concept_linking",
            "version_sensitive"
          ]
        },
        "presentation_hints": {
          "type": "array",
          "description": "正文可按内容需要采用的呈现方式建议；不是必填模板，也不是完成依据。",
          "default": [],
          "items": {
            "enum": [
              "concept_definition",
              "comparison_table",
              "mechanism_card",
              "case_card",
              "workflow_steps",
              "misconception_boundary",
              "review_hook"
            ]
          }
        },
        "completion_signal": {
          "type": "string",
          "description": "本节最值得回看的关键判断，不作为学习台验收方式。"
        },
        "risk_notes": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        }
      }
    },
    "knowledgeTree": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_question", "main_branches"],
      "properties": {
        "root_question": {
          "type": "string",
          "minLength": 1
        },
        "main_branches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/treeBranch"
          }
        },
        "structure_risks": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        }
      }
    },
    "treeBranch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch_id", "title", "learning_role", "child_nodes"],
      "properties": {
        "branch_id": {
          "type": "string",
          "pattern": "^branch_[0-9]{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "learning_role": {
          "type": "string"
        },
        "child_nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/treeNode"
          }
        }
      }
    },
    "treeNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "title", "node_role"],
      "properties": {
        "node_id": {
          "type": "string",
          "pattern": "^node_[0-9]{3}_[0-9]{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "node_role": {
          "type": "string",
          "description": "概念、机制、流程、对比、案例、边界、题干判断等。"
        },
        "expected_depth": {
          "enum": ["brief", "normal", "deep"]
        },
        "source_hints": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        }
      }
    },
    "crossLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "relation", "why_it_matters"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "relation": {
          "enum": [
            "same_boundary",
            "prerequisite",
            "contrast",
            "reused_concept",
            "common_error",
            "sequence",
            "example_of"
          ]
        },
        "why_it_matters": {
          "type": "string"
        }
      }
    }
  }
}
