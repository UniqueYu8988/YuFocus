            "link",
            "document",
            "other"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "missing",
            "planned",
            "attached"
          ]
        },
        "related_node_ids": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._-]{1,63}$"
          }
        }
      }
    },
    "informationGap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
