        }
      }
    },
    "assetRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "asset_type",
        "title",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]{1,63}$"
        },
        "asset_type": {
          "type": "string",
          "enum": [
            "image",
            "audio",
            "video",
