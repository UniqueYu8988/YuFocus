{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shijie-focus.local/schemas/course_package.schema.json",
  "title": "视界专注 Course Package",
  "description": "视界专注轻量学习台可导入的课程包 Schema。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "source",
    "course",
    "chapters",
    "dependency_graph",
    "assets",
    "gaps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "onboard.course-package.v0.1"
    },
    "package_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
    },
    "source": {
      "$ref": "#/$defs/sourceInfo"
    },
    "course": {
      "$ref": "#/$defs/courseInfo"
    },
    "course_visual_map": {
      "$ref": "#/$defs/courseVisualMap"
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/chapterNode"
      }
    },
    "dependency_graph": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/dependencyEdge"
      }
    },
    "assets": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/assetRef"
      }
    },
    "gaps": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/informationGap"
      }
    }
  },
  "$defs": {
    "sourceInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_id",
        "title",
        "language",
        "ingested_at",
        "text_length"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "bilibili_subtitle",
            "local_transcript",
            "audio_transcript",
            "merged_text",
            "manual_text"
          ]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "creator": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "ingested_at": {
          "type": "string",
          "format": "date-time"
        },
        "text_length": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "courseInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "overall_goal",
        "target_audience",
        "learning_outcomes",
        "completion_definition"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string"
        },
        "overall_goal": {
          "type": "string",
          "minLength": 1
        },
        "target_audience": {
          "type": "string",
          "minLength": 1
        },
        "prerequisites": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "learning_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "completion_definition": {
          "type": "string",
          "minLength": 1
        },
        "estimated_total_minutes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "chapterNode": {
      "allOf": [
        {
          "$ref": "#/$defs/outlineNode"
        },
        {
          "type": "object",
          "properties": {
            "node_type": {
              "const": "chapter"
            }
          }
        }
      ]
    },
    "outlineNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "node_type",
        "title",
        "summary",
        "order",
        "learning_objectives",
        "dependencies",
        "knowledge",
        "children",
        "assets",
        "gaps"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]{1,63}$"
        },
        "node_type": {
          "type": "string",
          "enum": [
            "chapter",
            "section",
            "lesson"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "learning_objectives": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "teacher_ready_content": {
          "$ref": "#/$defs/teacherReadyContent"
        },
        "chapter_roadmap": {
          "$ref": "#/$defs/chapterRoadmap"
        },
        "source_refs": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        },
        "dependencies": {
          "type": "array",
          "default": [],
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._-]{1,63}$"
          }
        },
        "knowledge": {
          "$ref": "#/$defs/knowledgeBlock"
        },
        "children": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/outlineNode"
          }
        },
        "assets": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/assetRef"
          }
        },
        "gaps": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/informationGap"
          }
        }
      }
    },
    "teacherReadyContent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lesson_profile": {
          "type": "string",
          "enum": [
            "concept",
            "operation",
            "tool_config",
            "exam",
            "case_analysis",
            "strategy",
            "mixed"
          ]
        },
        "lesson_type_tags": {
          "type": "array",
          "default": [],
          "description": "从课程蓝图保留下来的多维课型标签，用于未来展示层和 TTS/学习策略适配。",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "display_hints": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "primary_training_action": {
          "type": "string",
          "description": "从蓝图继承的主训练动作，例如 identify、operate、correct、troubleshoot。仅用于学习策略和审计，不要求学生端展示。"
        },
        "training_focus": {
          "type": "array",
          "default": [],
          "description": "本节实际落地的训练槽位，例如 near_miss_pairs、correction_drill、verification_step。仅用于审计和未来展示适配。",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "teaching_markdown": {
          "type": "string"
        },
        "quiz_question": {
          "type": "string"
        },
        "standard_answer": {
          "type": "string"
        },
        "key_points": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "common_mistakes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "memory_hook": {
          "type": "string"
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "label"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "material_block",
            "subtitle_segment",
            "transcript_excerpt",
            "material_package",
            "note",
            "other"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "block_id": {
          "type": "string"
        },
        "time_range": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "from": {
              "type": [
                "number",
                "null"
              ]
            },
            "to": {
              "type": [
                "number",
                "null"
              ]
            }
          }
        },
        "excerpt": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      }
    },
    "knowledgeBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "concepts",
        "examples",
        "checkpoints",
        "common_mistakes"
      ],
      "properties": {
        "concepts": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/conceptItem"
          }
        },
        "examples": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/exampleItem"
          }
        },
        "checkpoints": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "common_mistakes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_scope": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "teaching_expansion": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "practical_steps": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "practice_tasks": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "transfer_prompts": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "enrichment_notes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "conceptItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "explanation"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]{1,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "exampleItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "scenario",
        "takeaway"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]{1,63}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "scenario": {
          "type": "string",
          "minLength": 1
        },
        "takeaway": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "chapterRoadmap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roadmap_type",
        "title",
        "nodes"
      ],
      "properties": {
        "roadmap_type": {
          "type": "string",
          "enum": [
            "workflow",
            "concept_map",
            "decision_tree",
            "operation_flow",
            "exam_strategy",
            "architecture_map",
            "case_reasoning",
            "argument_map",
            "viewpoint_map"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string"
        },
        "visual_asset": {
          "$ref": "#/$defs/chapterRoadmapVisualAsset"
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/chapterRoadmapNode"
          }
        },
        "edges": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/chapterRoadmapEdge"
          }
        },
        "focus_cards": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/chapterRoadmapFocusCard"
          }
        },
        "completion_signals": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "turning_points": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/chapterRoadmapTurningPoint"
          }
        },
        "tension_edges": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/chapterRoadmapTensionEdge"
          }
        },
        "conflict_nodes": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/chapterRoadmapConflictNode"
          }
        },
        "open_questions": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/chapterRoadmapOpenQuestion"
          }
        }
      }
    },
    "chapterRoadmapVisualAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "alt",
        "prompt",
        "status"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^asset_[a-z0-9._-]{3,80}$"
        },
        "kind": {
          "type": "string",
          "const": "image"
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "alt": {
          "type": "string",
          "minLength": 8,
          "maxLength": 300
        },
        "prompt": {
          "type": "string",
          "minLength": 30,
          "maxLength": 2000
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "attached",
            "missing"
          ]
        },
        "hotspots": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/chapterRoadmapHotspot"
          }
        }
      }
    },
    "courseVisualMap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "alt",
        "prompt",
        "status"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^asset_[a-z0-9._-]{3,80}$"
        },
        "kind": {
          "type": "string",
          "const": "image"
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "alt": {
          "type": "string",
          "minLength": 8,
          "maxLength": 300
        },
        "prompt": {
          "type": "string",
          "minLength": 30,
          "maxLength": 2400
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "attached",
            "missing"
          ]
        },
        "hotspots": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/courseVisualMapHotspot"
          }
        }
      }
    },
    "courseVisualMapHotspot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^hotspot_[a-z0-9._-]{3,80}$"
        },
        "chapter_id": {
          "type": "string"
        },
        "lesson_id": {
          "type": "string"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 60
        },
        "x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    },
    "chapterRoadmapHotspot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^hotspot_[a-z0-9._-]{3,80}$"
        },
        "lesson_id": {
          "type": "string"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    },
    "chapterRoadmapNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^rm_[a-z0-9._-]{1,48}$"
        },
        "lesson_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]{1,63}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "map_label": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "micro_question": {
          "type": "string"
        },
        "action_tag": {
          "type": "string"
        },
        "risk_tag": {
          "type": "string"
        },
        "output_tag": {
          "type": "string"
        },
        "core_question": {
          "type": "string"
        },
        "key_claim": {
          "type": "string"
        },
        "counterpoint": {
          "type": "string"
        },
        "completion_signal": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "foundation",
            "concept",
            "practice",
            "risk",
            "decision",
            "review",
            "integration"
          ]
        },
        "tone": {
          "type": "string",
          "enum": [
            "green",
            "blue",
            "purple",
            "amber",
            "rose",
            "neutral"
          ]
        }
      }
    },
    "chapterRoadmapEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string",
          "pattern": "^rm_[a-z0-9._-]{1,48}$"
        },
        "to": {
          "type": "string",
          "pattern": "^rm_[a-z0-9._-]{1,48}$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "next",
            "depends_on",
            "contrast",
            "risk",
            "feedback",
            "supports",
            "tension",
            "counterpoint",
            "tradeoff",
            "open_question"
          ]
        },
        "label": {
          "type": "string"
        }
      }
    },
    "chapterRoadmapFocusCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "bullets"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "bullets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "chapterRoadmapTurningPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "reason"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "lesson_ids": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "chapterRoadmapTensionEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "tension"
      ],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "tension": {
          "type": "string",
          "minLength": 1
        },
        "resolution_hint": {
          "type": "string"
        }
      }
    },
    "chapterRoadmapConflictNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "claim",
        "counterpoint",
        "why_it_matters"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "counterpoint": {
          "type": "string",
          "minLength": 1
        },
        "why_it_matters": {
          "type": "string",
          "minLength": 1
        },
        "lesson_ids": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "chapterRoadmapOpenQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
